<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UniSync.Client.ViewModels"
             xmlns:shared="using:UniSync.Shared.Models"
             x:Class="UniSync.Client.Views.CommitsView"
             x:DataType="vm:CommitsViewModel"
             Background="#F5F5F7">

    <Grid RowDefinitions="Auto, *, Auto">
        <Border Grid.Row="0" Background="White" Padding="15">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Content="◀ Назад" Command="{Binding BackToScheduleCommand}" Background="Transparent"/>
                <TextBlock Grid.Column="1" Text="Модерация правок" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                <Button Grid.Column="2" Content="Обновить" Command="{Binding LoadCommitsCommand}" Background="Transparent" Foreground="#007AFF"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <ScrollViewer IsVisible="{Binding !IsLoading}">
                <ItemsControl ItemsSource="{Binding Commits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="shared:ScheduleCommit">
                            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,4">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="Bold" Text="{Binding OldTitle}"/>
                                    <TextBlock FontSize="12" Foreground="#8E8E93" Text="{Binding StartTime, StringFormat='Время: {0}'}"/>
                                    <TextBlock FontSize="12" Foreground="#8E8E93" Text="{Binding LessonDate, StringFormat='Дата: {0:dd.MM.yyyy}'}"/>
                                    <TextBlock FontSize="12" Text="{Binding NewTitle, StringFormat='Название: {0}'}"
                                               IsVisible="{Binding NewTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock FontSize="12" Text="{Binding NewRoom, StringFormat='Аудитория: {0}'}"
                                               IsVisible="{Binding NewRoom, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock FontSize="12" Text="{Binding NewTeacher, StringFormat='Преподаватель: {0}'}"
                                               IsVisible="{Binding NewTeacher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Status, StringFormat='Статус: {0}'}"/>
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8" IsVisible="{Binding IsPending}">
                                        <Button Grid.Column="0" Content="Одобрить" Command="{Binding $parent[UserControl].((vm:CommitsViewModel)DataContext).ApproveCommand}"
                                                CommandParameter="{Binding}" Background="#34C759" Foreground="White"/>
                                        <Button Grid.Column="1" Content="Отклонить" Command="{Binding $parent[UserControl].((vm:CommitsViewModel)DataContext).RejectCommand}"
                                                CommandParameter="{Binding}" Background="#FF3B30" Foreground="White"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Margin="10">
            <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Foreground="#8E8E93"/>
            <Button Content="Выход" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch"
                    Background="Transparent" Foreground="#FF3B30" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
