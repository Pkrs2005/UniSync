<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UniSync.Client.ViewModels"
             xmlns:views="using:UniSync.Client.Views"
             x:Class="UniSync.Client.Views.MainView"
             x:DataType="vm:MainViewModel">
    
    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:LoginViewModel">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="vm:RegisterViewModel">
            <views:RegisterView />
        </DataTemplate>
        <DataTemplate DataType="vm:ScheduleViewModel">
            <views:ScheduleView />
        </DataTemplate>
        <DataTemplate DataType="vm:CommitsViewModel">
            <views:CommitsView />
        </DataTemplate>
    </UserControl.DataTemplates>

    <ContentControl Content="{Binding CurrentPage}" />
</UserControl>